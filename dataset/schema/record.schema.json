{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clay-good/harmonia/dataset/schema/record.schema.json",
  "title": "Harmonia record",
  "description": "A single channel-block, ap-model, drug-reference, or population record. The dataset is the source of truth; everything else is a deterministic projection.",
  "type": "object",
  "required": ["id", "kind", "subsystem", "tier", "extraction"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_.-]+$",
      "description": "Stable dotted id, e.g. channel_block.dofetilide.ikr"
    },
    "kind": { "enum": ["channel_block", "ap_model", "drug_reference", "population"] },
    "subsystem": {
      "enum": [
        "ion_channels",
        "channel_block",
        "ap_models",
        "risk_metrics",
        "drug_reference_sets",
        "exposure",
        "populations"
      ]
    },
    "tier": { "enum": ["A", "B", "C", "D"] },
    "primary_citation": { "type": "string" },
    "notes": { "type": "string" },
    "extraction": {
      "type": "object",
      "required": ["review_status"],
      "additionalProperties": false,
      "properties": {
        "review_status": { "enum": ["verified", "unverified", "contested"] },
        "method": { "type": "string" },
        "verified_by": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },

    "drug": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "unii": { "type": ["string", "null"] },
        "chembl": { "type": ["string", "null"] }
      }
    },
    "channel": { "enum": ["IKr", "IKs", "ICaL", "INaL", "INa", "Ito", "IK1"] },
    "block_model": { "enum": ["hill", "dynamic_binding"] },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "value"],
        "additionalProperties": false,
        "properties": {
          "symbol": { "type": "string" },
          "label": { "type": "string" },
          "value": {
            "type": "object",
            "required": ["central", "units"],
            "additionalProperties": false,
            "properties": {
              "central": { "type": "number" },
              "low": { "type": ["number", "null"] },
              "high": { "type": ["number", "null"] },
              "units": { "type": "string" }
            }
          },
          "tier": { "enum": ["A", "B", "C", "D"] },
          "primary_citation": { "type": "string" }
        }
      }
    },
    "dynamic_binding": {
      "type": "object",
      "description": "Time-dependent (CiPA-style) hERG drug-binding kinetics. Langmuir first-order: db/dt = kon*conc*(1-b) - koff*open_factor*b, IC50 = koff/kon.",
      "additionalProperties": false,
      "required": ["kon", "koff", "trapping"],
      "properties": {
        "kon": { "type": "number", "exclusiveMinimum": 0, "description": "association rate, 1/(nM*ms)" },
        "koff": { "type": "number", "exclusiveMinimum": 0, "description": "dissociation rate, 1/ms" },
        "trapping": { "type": "boolean", "description": "drug trapped in the closed channel (unbinds only from the activated state)" },
        "citation": { "type": ["string", "null"] }
      }
    },
    "assay_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": {
          "enum": ["manual_patch_clamp", "automated_patch_clamp", "mixed", "unknown"]
        },
        "temperature_c": { "type": ["number", "null"] },
        "expression_system": { "type": ["string", "null"] },
        "max_block_observed_percent": { "type": ["number", "null"] },
        "holding_protocol": { "type": ["string", "null"] }
      }
    },
    "source_values": {
      "type": "array",
      "description": "Multiple labs'/assays' measurements of the same IC50 — the variability made first-class.",
      "items": {
        "type": "object",
        "required": ["ic50_nm", "citation"],
        "additionalProperties": false,
        "properties": {
          "ic50_nm": { "type": "number", "exclusiveMinimum": 0 },
          "hill": { "type": ["number", "null"] },
          "platform": {
            "enum": ["manual", "automated", "mixed", "unknown"]
          },
          "temperature_c": { "type": ["number", "null"] },
          "max_block_observed_percent": { "type": ["number", "null"] },
          "citation": { "type": "string" },
          "fit_sd_log10": {
            "type": ["number", "null"],
            "exclusiveMinimum": 0,
            "description": "v0.2 summary regime: per-source fit SD (log10 nM) of the fitted IC50, if known."
          },
          "dose_response": {
            "type": "object",
            "description": "v0.2 raw regime (optional upgrade path): raw concentration-block points that let the IC50/Hill be INFERRED rather than transcribed (spec v0.2 sec 3). Records without it fall back to the summary regime.",
            "additionalProperties": false,
            "required": ["concentration_nm", "fractional_block"],
            "properties": {
              "concentration_nm": { "type": "array", "items": { "type": "number", "exclusiveMinimum": 0 } },
              "fractional_block": { "type": "array", "items": { "type": "number", "minimum": 0, "maximum": 1 } },
              "n_cells": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
              "sem": { "type": "array", "items": { "type": "number", "minimum": 0 } },
              "likelihood": { "enum": ["truncated_normal", "beta"] },
              "top_dose_censored": { "type": "boolean" }
            }
          }
        }
      }
    },
    "inference": {
      "type": "object",
      "description": "v0.2 per-channel posterior contract (spec v0.2 sec 3). OPTIONAL: when absent, the channel is inferred under the pinned default prior at assess time. The posterior_summary is a CACHED, generated projection of (source data + prior) — never hand-edited.",
      "additionalProperties": false,
      "properties": {
        "method": { "enum": ["hierarchical_bayes", "method_of_moments"] },
        "prior": { "type": "string", "description": "FK into the prior registry (dataset/priors/)" },
        "censored": { "type": "boolean" },
        "posterior_summary": {
          "type": "object",
          "additionalProperties": true,
          "description": "Cached sampler output (mean/sd/quantiles + rhat/ess + identifiability/prior-sensitivity). Regenerable by build_posteriors.py."
        }
      }
    },
    "variability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fold_range": { "type": ["number", "null"] },
        "n_sources": { "type": "integer", "minimum": 0 },
        "iqr_nm": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "geomean_nm": { "type": ["number", "null"] }
      }
    },
    "known_failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "behavior", "action"],
        "additionalProperties": false,
        "properties": {
          "condition": { "type": "string" },
          "behavior": { "type": "string" },
          "action": { "type": "string" },
          "citation": { "type": ["string", "null"] }
        }
      }
    },

    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "lineage": { "type": "string" },
        "formulation": { "type": "string" },
        "currents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "model_parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["symbol", "value", "units"],
        "additionalProperties": false,
        "properties": {
          "symbol": { "type": "string" },
          "label": { "type": "string" },
          "value": { "type": "number" },
          "units": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "training_set_reproduced": { "type": ["boolean", "null"] },
        "validation_set_accuracy": { "type": ["number", "null"] },
        "notes": { "type": "string" }
      }
    },

    "cipa_set": { "enum": ["training", "validation", "none"] },
    "expert_risk_label": { "enum": ["high", "intermediate", "low"] },
    "eftpc_nm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["central", "units"],
      "properties": {
        "central": { "type": "number" },
        "units": { "type": "string" },
        "kind": { "enum": ["free", "total"] },
        "citation": { "type": "string" }
      }
    },
    "protein_binding": {
      "type": "object",
      "description": "Plasma protein binding used to scale total <-> free exposure. free = fraction_unbound * total.",
      "additionalProperties": false,
      "required": ["fraction_unbound"],
      "properties": {
        "fraction_unbound": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "total_cmax_nm": { "type": ["number", "null"] },
        "citation": { "type": ["string", "null"] }
      }
    },
    "population": {
      "type": "object",
      "description": "Population-of-models spec: per-conductance coefficient of variation used to sample a population of virtual myocytes. HYPOTHESIS-TIER (Tier D) — illustrative inter-individual variability, NOT calibrated to real human data, NOT for prediction.",
      "additionalProperties": false,
      "required": ["name", "conductance_cv"],
      "properties": {
        "name": { "type": "string" },
        "n_default": { "type": "integer", "minimum": 1 },
        "conductance_cv": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 },
          "description": "channel/conductance -> coefficient of variation (lognormal) for the population"
        },
        "conductance_scale": {
          "type": "object",
          "additionalProperties": { "type": "number", "exclusiveMinimum": 0 },
          "description": "v0.3 disease/genetic background: channel/conductance -> MEAN multiplier (default 1), applied under the conductance_cv spread. Illustrative, hypothesis-tier (Tier D), NOT predictive."
        },
        "calibration": {
          "type": "object",
          "description": "v0.5 experimentally-calibrated population (Britton et al. 2013): a candidate virtual myocyte is accepted into the population only if its DRUG-FREE action-potential biomarkers all fall within the declared ranges (and it repolarizes). Removes the implausible/abnormal tail of the prior conductance cloud, leaving a physiologically plausible population. The ranges are kernel-plausibility bounds (the kernel's own units), NOT patient-fit data, so a calibrated assessment stays hypothesis-tier (Tier D), NOT predictive.",
          "additionalProperties": false,
          "required": ["method", "citation", "biomarkers"],
          "properties": {
            "method": { "type": "string" },
            "citation": { "type": "string" },
            "max_oversample": {
              "type": "integer", "minimum": 1,
              "description": "cap on candidates drawn per accepted myocyte before giving up (determinism / termination guard)"
            },
            "biomarkers": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["min", "max"],
                "properties": { "min": { "type": "number" }, "max": { "type": "number" } }
              },
              "description": "biomarker name (apd90_ms | vrest_mv | vpeak_mv | triangulation_ms) -> accepted [min, max] range in the kernel's units"
            }
          }
        },
        "predictive": { "const": false }
      }
    }
  },

  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "channel_block" } } },
      "then": { "required": ["drug", "channel", "block_model", "parameters", "assay_context"] }
    },
    {
      "if": { "properties": { "kind": { "const": "ap_model" } } },
      "then": { "required": ["model"] }
    },
    {
      "if": { "properties": { "kind": { "const": "drug_reference" } } },
      "then": { "required": ["drug", "cipa_set", "expert_risk_label", "eftpc_nm"] }
    },
    {
      "if": { "properties": { "kind": { "const": "population" } } },
      "then": { "required": ["population"], "properties": { "tier": { "const": "D" } } }
    }
  ]
}
